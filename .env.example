# Copy to .env.local for local dev, and add the same vars in Vercel
# (Project → Settings → Environment Variables). All are OPTIONAL — the site
# runs without them (newsletter falls back to demo mode).

# ─── Newsletter ───────────────────────────────────────────────────────────
# Pick ONE provider, then fill that provider's keys.
# NEWSLETTER_PROVIDER=convertkit | beehiiv | mailchimp
NEWSLETTER_PROVIDER=

# ConvertKit
CONVERTKIT_API_KEY=
CONVERTKIT_FORM_ID=

# Beehiiv
BEEHIIV_API_KEY=
BEEHIIV_PUBLICATION_ID=

# Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
MAILCHIMP_SERVER_PREFIX=   # e.g. us21 (the bit after the dash in your API key)

# ─── Search Console (optional) ────────────────────────────────────────────
# Prefer pasting the token into config/site.ts (googleSiteVerification).
